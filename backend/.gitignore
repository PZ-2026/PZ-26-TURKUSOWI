backend/out/
local.properties

# IntelliJ/STS/Eclipse
backend/.classpath
backend/.project
backend/.settings/
backend/.factorypath

# Wrapper cache (nie ignorujemy samych plików wrappera)
!backend/gradlew
!backend/gradlew.bat
!backend/gradle/wrapper/gradle-wrapper.jar
!backend/gradle/wrapper/gradle-wrapper.properties

